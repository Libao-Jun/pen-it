{
  "name": "pen-it",
  "version": "2.0.1",
  "description": "用笔锚定记忆中的常用 JavaScript / TypeScript 工具集，一个轻量级的实工具库",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist && rolldown -c rolldown.config.js && node scripts/strip-dts-comments.mjs",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "pen-it",
    "utils",
    "tools",
    "utility"
  ],
  "author": "newborn_calf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Libao-Jun/pen-it"
  },
  "homepage": "https://github.com/Libao-Jun/pen-it#readme",
  "bugs": {
    "url": "https://github.com/Libao-Jun/pen-it/issues"
  },
  "packageManager": "pnpm@10.19.0",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "rimraf": "^6.1.3",
    "rolldown": "^1.0.3",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}