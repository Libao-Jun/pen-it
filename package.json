{
  "name": "pen-it",
  "version": "1.0.2",
  "description": "用笔锚定记忆中的前端常用工具函数 — A lightweight frontend utility library for type checking, date/number formatting, string manipulation, storage, deep clone, array operations, cookies, and browser APIs",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist && rolldown -c rolldown.config.js",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "utils",
    "utilities",
    "toolkit",
    "helpers",
    "frontend",
    "typescript",
    "type-checking",
    "date-format",
    "number-format",
    "deep-clone",
    "string-manipulation",
    "array-operations",
    "cookie",
    "localstorage",
    "browser-api",
    "debounce",
    "throttle"
  ],
  "author": "newborn_calf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/newborn_calf/pen-it"
  },
  "homepage": "https://github.com/newborn_calf/pen-it#readme",
  "bugs": {
    "url": "https://github.com/newborn_calf/pen-it/issues"
  },
  "packageManager": "pnpm@10.19.0",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "rimraf": "^6.1.3",
    "rolldown": "^1.0.3",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}